{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://odoo.common/schema/form_capture_shell.schema.json",
  "title": "Form Capture Shell Contract",
  "type": "object",
  "required": [
    "form_shell",
    "layout",
    "anchor",
    "columns"
  ],
  "properties": {
    "form_shell": {
      "const": "capture"
    },
    "layout": {
      "enum": [
        "two-column"
      ]
    },
    "anchor": {
      "enum": [
        "before-lines"
      ]
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slot"
        ],
        "properties": {
          "slot": {
            "enum": [
              "primary",
              "secondary"
            ]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "section_title": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
