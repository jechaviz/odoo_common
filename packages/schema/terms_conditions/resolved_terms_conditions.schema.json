{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.local/odoo-common/schema/terms-conditions/resolved-terms-conditions.schema.json",
  "title": "Resolved Terms And Conditions Payload",
  "description": "Document-ready terms payload after inheritance and scope resolution.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "locale_code": {
      "type": "string",
      "minLength": 2
    },
    "body_markdown": {
      "type": "string",
      "minLength": 1
    },
    "rendered_html": {
      "type": "string"
    },
    "revision_label": {
      "type": "string",
      "minLength": 1
    },
    "effective_from": {
      "type": "string",
      "format": "date"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "render_profile": {
      "type": "string",
      "minLength": 1
    },
    "source_checksum_sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "origin_scope": {
      "type": "string",
      "minLength": 1
    },
    "resolution_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "record_model": {
            "type": "string",
            "minLength": 1
          },
          "record_id": {
            "type": "integer",
            "minimum": 1
          },
          "record_key": {
            "type": "string",
            "minLength": 1
          },
          "matched_on": {
            "type": "string",
            "minLength": 1
          },
          "applied": {
            "type": "boolean"
          }
        },
        "required": [
          "scope",
          "applied"
        ]
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "key",
    "title",
    "locale_code",
    "body_markdown",
    "origin_scope",
    "resolution_path"
  ]
}
